{
    "build": {
        "beforeDevCommand": "pnpm run dev",
        "beforeBuildCommand": "pnpm run build:vite",
        "devUrl": "http://localhost:1420",
        "frontendDist": "../dist"
    },
    "productName": "Heos Controller",
    "version": "2.0.1",
    "identifier": "me.christopherd.heos-controller",
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Heos Controller",
                "width": 350,
                "height": 413,
                "minWidth": 350,
                "minHeight": 413,
                "center": true,
                "resizable": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "macOS": {
            "entitlements": "Entitlements.plist"
        }
    }
}