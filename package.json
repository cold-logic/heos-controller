{
  "name": "heos-controller",
  "version": "1.0.12",
  "description": "Controller for Denon Heos speakers",
  "repository": "https://github.com/cold-logic/heos-controller",
  "main": "app/index.js",
  "scripts": {
    "sync-version": "node sync-version.js",
    "pack": "pnpm run sync-version && env-cmd electron-builder",
    "dist": "pnpm run sync-version && env-cmd electron-builder",
    "build": "pnpm run sync-version && env-cmd electron-builder build",
    "package-linux": "pnpm run sync-version && env-cmd electron-builder --linux",
    "package-mac": "pnpm run sync-version && env-cmd electron-builder --mac --arm64 --x64",
    "package-win": "pnpm run sync-version && env-cmd electron-builder --win --ia32 --x64",
    "release": "build",
    "start": "pnpm run sync-version && electron app",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "Christopher Davison",
  "private": true,
  "license": "ISC",
  "build": {
    "appId": "me.christopherd.heos-controller",
    "productName": "Heos Controller",
    "directories": {
      "app": "app",
      "output": "dist",
      "buildResources": "build"
    },
    "mac": {
      "icon": "icon.icns",
      "category": "public.app-category.music",
      "identity": null
    },
    "linux": {
      "icon": "icon.icns",
      "category": "public.app-category.music",
      "target": "AppImage"
    },
    "publish": {
      "provider": "generic",
      "url": "https://github.com/cold-logic/heos-controller/releases/latest/download/"
    }
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.11.3",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "jquery": "^4.0.0",
    "jquery-knob": "ssh://git@github.com:aterrien/jQuery-Knob.git",
    "jsonfile": "6.2.1"
  },
  "devDependencies": {
    "electron": "^41.3.0",
    "electron-builder": "26.8.2",
    "electron-builder-squirrel-windows": "26.8.2",
    "env-cmd": "^11.0.0"
  },
  "pnpm": {
    "overrides": {
      "@isaacs/brace-expansion@<=5.0.0": "5.0.1",
      "minimatch@<3.1.4": "3.1.5",
      "minimatch@>=5.0.0 <5.1.8": "5.1.9",
      "minimatch@>=9.0.0 <9.0.7": "9.0.9",
      "minimatch@>=10.0.0 <10.2.3": "10.2.4",
      "tmp@<=0.2.3": ">=0.2.4",
      "ajv@<6.14.0": ">=6.14.0",
      "tar@<=7.5.10": ">=7.5.11",
      "brace-expansion@<1.1.13": ">=1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3",
      "brace-expansion@>=4.0.0 <5.0.5": ">=5.0.5",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "lodash@>=4.0.0 <=4.17.23": ">=4.18.0",
      "lodash@<=4.17.23": ">=4.18.0",
      "@xmldom/xmldom@<0.8.12": ">=0.8.12",
      "@xmldom/xmldom@<0.8.13": ">=0.8.13"
    }
  },
  "workspaces": [
    "app"
  ],
  "packageManager": "pnpm@10.13.1+sha512.37ebf1a5c7a30d5fabe0c5df44ee8da4c965ca0c5af3dbab28c3a1681b70a256218d05c81c9c0dcf767ef6b8551eb5b960042b9ed4300c59242336377e01cfad"
}
